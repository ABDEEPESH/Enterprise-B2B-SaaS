# Enterprise B2B SaaS Platform - Frontend Environment Variables
# This file is used by Vite and will be loaded automatically

# API Configuration
VITE_API_BASE_URL=http://localhost:8081/api/v1

# App Configuration
VITE_APP_NAME=Enterprise B2B SaaS Platform
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
