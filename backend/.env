# Enterprise B2B SaaS Platform - Backend Environment Variables
# Copy this file to .env and update with your actual values

# Database Configuration
# IMPORTANT: Use SPRING_DATA_MONGODB_URI for Spring Boot
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# NOTE: If your password contains special characters (@, #, etc.), URL encode them:
#   @ → %40, # → %23, / → %2F, + → %2B, etc.
# Your password has @ which must be encoded as %40

SPRING_DATA_MONGODB_URI=mongodb+srv://ABDEEPESH:A%40b_deepesh27102005@cluster0.zouwsq7.mongodb.net/enterprise_b2b_platform?retryWrites=true&w=majority

# Fallback for legacy configs
MONGODB_URI=mongodb+srv://ABDEEPESH:A%40b_deepesh27102005@cluster0.zouwsq7.mongodb.net/enterprise_b2b_platform?retryWrites=true&w=majority
MONGODB_DATABASE=enterprise_b2b_platform

# Server Configuration
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/

# Spring Profiles
SPRING_PROFILES_ACTIVE=dev

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app,https://localhost:3000,https://localhost:5173,http://localhost:3000,http://localhost:5173

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourcompany.com
EMAIL_FROM_NAME=Enterprise Platform

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/enterprise-platform.log

# Application Configuration
APP_NAME=Enterprise B2B SaaS Platform
APP_VERSION=1.0.0
APP_DESCRIPTION=Enterprise-grade B2B SaaS platform backend

# Monitoring Configuration
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# Production Settings (Uncomment for production)
# SPRING_PROFILES_ACTIVE=prod
# LOG_LEVEL=WARN
# MONGODB_URI=mongodb://username:password@cluster-host:27017/enterprise_b2b_platform_prod?authSource=admin&ssl=true&replicaSet=rs0
